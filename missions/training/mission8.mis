	Checkpoint { Origin 6150.0;1675.0;64.0      Radius 200  Type sea }
	Checkpoint { Origin 6350.0;1670.0;64.0      Radius 200  Type sea }
	Checkpoint { Origin 6550.0;1660.0;64.0      Radius 200  Type sea }
}
Objectives
