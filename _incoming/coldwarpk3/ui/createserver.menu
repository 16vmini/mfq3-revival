// BUTTONS & TEXT

// BACK

itemDef {
      	name back
	style 3
      	background "ui/assets/backarrow.tga"
	rect 20 440 32 32 
      	visible 1 
	mouseEnter { hide back ; show back_on }
    	}

itemDef {
      	name back_on
      	style WINDOW_STYLE_SHADER
	background "ui/assets/backarrow_on.tga"
	rect 20 440 32 32 
      	forecolor 1 1 1 1
      	visible 0
	type ITEM_TYPE_BUTTON
      	mouseExit { hide back_on ; show back }	  
      	action { play "sound/misc/kcaction.wav" ; close createserver ; open play }
    	}

itemDef {
	name back_text
	group grpControlbutton
	text "Back to play menu"
	textscale .25
	textalignx 11
	textaligny 12
	rect 44 450 60 20 
	style 1
	forecolor 1 1 1 1
	visible 1
	decoration
	}

// START SERVER

itemDef {
      	name accept
	style 3
      	background "ui/assets/acceptarrow.tga"
	rect 590 440 32 32
      	visible 1 
	mouseEnter { hide accept ; show accept_on }
    	}

itemDef {
      	name accept_on
      	style WINDOW_STYLE_SHADER
	background "ui/assets/acceptarrow_on.tga"
	rect 590 440 32 32 
      	forecolor 1 1 1 1
      	visible 0
	type ITEM_TYPE_BUTTON
      	mouseExit { hide accept_on ; show accept }	  
      	action { play "sound/misc/kcaction.wav" ; uiScript StartServer }	  
    	}

itemDef {
	name accept_text
	group grpControlbutton
	text "Start Server"
	textscale .25
	textalignx 11
	textaligny 12
	rect 508 450 60 20 
	style 1
	forecolor 1 1 1 1
	visible 1
	decoration
	}
}

