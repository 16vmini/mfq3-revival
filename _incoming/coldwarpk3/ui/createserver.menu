#include "ui/menudef.h"

// CREATE SERVER
{

menuDef {
    	name "createserver"
    	visible 0
    	fullscreen 1
    	rect 0 0 640 480
	background "ui/assets/menuback.jpg"
	outOfBoundsClick	
	focusColor 1 1 1 1
    	style 1
    	border 1
	onEsc { close createserver ; open main }
	onOpen { uiScript loadArenas ;
	hide accept_alt ; 
	show accept ;
	hide back_alt ;
	show back }

// MAP PREVIEW

